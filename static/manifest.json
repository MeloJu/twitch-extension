{
  "manifest_version": 3,
  "name": "YouTube x Twitch Chat Bridge",
  "description": "Open Twitch chat while watching YouTube live.",
  "version": "0.1.0",
  "permissions": ["storage", "tabs", "activeTab", "sidePanel"],
  "host_permissions": ["*://www.youtube.com/*", "*://youtube.com/*", "*://www.twitch.tv/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "YT Twitch Bridge"
  },
  "options_page": "options.html",
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*", "*://youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
