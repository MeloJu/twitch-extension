{
  "name": "yt-twitch-chat-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Browser extension to open Twitch chat while watching YouTube live.",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs --chrome",
    "build:chrome": "node scripts/build.mjs --chrome",
    "build:firefox": "node scripts/build.mjs --firefox",
    "dev": "node scripts/build.mjs --watch --chrome",
    "dev:chrome": "node scripts/build.mjs --watch --chrome",
    "dev:firefox": "node scripts/build.mjs --watch --firefox",
    "clean": "node scripts/clean.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,html,css}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --max-warnings=0"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.24.0",
    "@playwright/test": "^1.53.0",
    "@types/chrome": "^0.0.321",
    "@types/node": "^22.15.3",
    "commitlint": "^19.8.0",
    "esbuild": "^0.25.3",
    "eslint": "^9.24.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "playwright": "^1.53.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.2"
  }
}
